# .env.example
# Plantilla de variables de entorno — openspec-constitution v1.1.0
#
# Copiar este archivo como `.env` y completar con valores reales.
# NUNCA commitear `.env` al repo (debe estar en `.gitignore`).

# --- Runtime ---
NODE_ENV=development

# --- Logging ---
LOG_LEVEL=debug  # trace | debug | info | warn | error | fatal

# --- Ejemplos comunes (descomentar y ajustar según el repo) ---
# APP_SECRET=
# PRIVATE_KEY_B64=

# --- Base de datos ---
# DB_CLUSTER_ENDPOINT=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# --- AWS ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=